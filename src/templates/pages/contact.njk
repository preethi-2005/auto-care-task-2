{% extends "../layouts/base.njk" %}
{% set title = "Contact" %}

{% block content %}

<!-- HERO -->
<div class="contact-hero text-white text-center d-flex align-items-center">
  <div class="container">
    <h1 class="fw-bold">Get In Touch</h1>
    <p class="mt-3">We’re here to help you with your car service needs</p>
  </div>
</div>
<div class="container py-5">

  <div class="row g-4">

    <!-- LEFT INFO -->
    <div class="col-md-6">
      <h3>Contact Information</h3>
      <p><strong>Email:</strong> support@autocare.com</p>
      <p><strong>Phone:</strong> 9999999999</p>
      <p><strong>Location:</strong> Hyderabad, India</p>
    </div>

    <!-- RIGHT FORM -->
    <div class="col-md-6">
      <div class="col-md-6">
  <div class="card p-4 shadow">

    <h5 class="mb-3">Send a Message</h5>

    <form id="contactForm">

      <input type="text" id="cname" class="form-control mb-3" placeholder="Your Name" required>

      <input type="email" id="cemail" class="form-control mb-3" placeholder="Your Email" required>

      <textarea id="cmsg" class="form-control mb-3" rows="4" placeholder="Message" required></textarea>

      <div id="successMsg" class="alert alert-success d-none">
        ✅ Message sent successfully!
      </div>

      <button type="submit" class="btn btn-warning w-100">
        Send Message
      </button>

    </form>

  </div>
</div>
    </div>

  </div>

</div>
<div class="container pb-5">
  <iframe
    src="https://www.google.com/maps?q=Hyderabad&output=embed"
    width="100%"
    height="300"
    style="border:0; border-radius:10px;">
  </iframe>
</div>

{% endblock %}