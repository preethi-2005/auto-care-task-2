{% extends "../layouts/base.njk" %}
{% set title = "About" %}

{% block content %}

<!-- HERO -->
<div class="contact-hero text-white text-center d-flex align-items-center">
  <div class="container">
    <h1 class="fw-bold">About AutoCare</h1>
    <p class="mt-3">Driven by trust. Powered by precision.</p>
  </div>
</div>

<!-- ABOUT SECTION -->
<div class="container py-5">
  <div class="row align-items-center">

    <!-- TEXT -->
    <div class="col-md-6">
      <h2>Who We Are</h2>
      <p>
        AutoCare is a premium car service platform focused on delivering
        high-quality automotive care with transparency and trust.
      </p>

      <p>
        From basic maintenance to luxury detailing, our certified technicians
        ensure your car gets the best treatment.
      </p>

      <ul>
        <li>✔ Certified Experts</li>
        <li>✔ Transparent Pricing</li>
        <li>✔ Pickup & Delivery</li>
        <li>✔ 100% Customer Satisfaction</li>
      </ul>
    </div>

    <!-- IMAGE -->
    <div class="col-md-6">
      <img src="/assets/images/car1.jpg" class="img-fluid rounded shadow">
    </div>

  </div>
</div>

<!-- WHY CHOOSE US -->
<div class="container py-5 text-center">
  <h2 class="mb-4">Why Choose Us</h2>

  <div class="row g-4">

    <div class="col-md-4">
      <div class="info-box">
        <h4>Expert Technicians</h4>
        <p>Highly trained professionals with years of experience.</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="info-box">
        <h4>Quick Service</h4>
        <p>Fast turnaround time without compromising quality.</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="info-box">
        <h4>Affordable Pricing</h4>
        <p>Premium service at competitive prices.</p>
      </div>
    </div>

  </div>
</div>

<!-- STATS -->
<div class="container py-5 text-center">
  <h2 class="mb-4">Our Impact</h2>

  <div class="row">

    <div class="col-md-3">
      <h2 class="text-warning">10K+</h2>
      <p>Cars Serviced</p>
    </div>

    <div class="col-md-3">
      <h2 class="text-warning">5K+</h2>
      <p>Happy Customers</p>
    </div>

    <div class="col-md-3">
      <h2 class="text-warning">15+</h2>
      <p>Years Experience</p>
    </div>

    <div class="col-md-3">
      <h2 class="text-warning">4.9⭐</h2>
      <p>Customer Rating</p>
    </div>

  </div>
</div>

{% endblock %}